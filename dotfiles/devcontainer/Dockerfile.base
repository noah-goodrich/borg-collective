# =============================================================================
# Base devcontainer image — shared across all projects.
# Provides: zsh, neovim (latest), tmux, git, ssh, claude-code CLI.
#
# Projects extend this with their own deps:
#   FROM devcontainer-base:local
#
# NOTE: Detects architecture automatically (arm64 or amd64).
# =============================================================================
FROM python:3.12-bookworm

# ── Create dev user ──────────────────────────────────────────────────────────
RUN groupadd --gid 1000 dev \
    && useradd --uid 1000 --gid 1000 -m -s /bin/zsh dev

# ── System tools ─────────────────────────────────────────────────────────────
RUN apt-get update && export DEBIAN_FRONTEND=noninteractive \
    && apt-get -y install --no-install-recommends \
    curl \
    fd-find \
    fzf \
    git \
    iputils-ping \
    jq \
    less \
    man-db \
    openssl \
    ripgrep \
    sudo \
    tmux \
    tree \
    unzip \
    vim \
    wget \
    zsh \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* \
    && ln -sf /usr/bin/fdfind /usr/local/bin/fd

# ── Give dev passwordless sudo (matches devcontainer convention) ──────────
RUN echo "dev ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/dev

# ── Neovim (latest stable — apt version is too old for modern plugins) ───────
RUN ARCH=$(dpkg --print-architecture) \
    && if [ "$ARCH" = "arm64" ]; then NVIM_PKG="nvim-linux-arm64"; \
       else NVIM_PKG="nvim-linux64"; fi \
    && curl -fsSL "https://github.com/neovim/neovim/releases/latest/download/${NVIM_PKG}.tar.gz" \
       -o /tmp/nvim.tar.gz \
    && tar xzf /tmp/nvim.tar.gz -C /opt \
    && ln -sf "/opt/${NVIM_PKG}/bin/nvim" /usr/local/bin/nvim \
    && rm /tmp/nvim.tar.gz

# ── GitHub CLI ───────────────────────────────────────────────────────────────
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
      | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
      > /etc/apt/sources.list.d/github-cli.list \
    && apt-get update -qq && apt-get install -y -qq gh && rm -rf /var/lib/apt/lists/*

# ── Node.js + Claude Code CLI ────────────────────────────────────────────────
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* \
    && npm install -g @anthropic-ai/claude-code

# ── Default shell ────────────────────────────────────────────────────────────
RUN chsh -s /bin/zsh dev

# ── Zsh plugins (fallback — host bind-mount overlays when present) ───────────
USER dev
RUN mkdir -p /home/dev/.config/zsh \
    && git clone --depth=1 https://github.com/romkatv/powerlevel10k.git \
         /home/dev/.config/zsh/powerlevel10k \
    && git clone --depth=1 https://github.com/zsh-users/zsh-autosuggestions \
         /home/dev/.config/zsh/zsh-autosuggestions \
    && git clone --depth=1 https://github.com/zsh-users/zsh-syntax-highlighting \
         /home/dev/.config/zsh/zsh-syntax-highlighting
USER root

# ── Claude Code — initialize config so first launch doesn't error ─────────────
RUN mkdir -p /home/dev \
    && echo '{}' > /home/dev/.claude.json \
    && chown dev:dev /home/dev/.claude.json

# ── SSH dir — pre-create so the selective file mounts in docker-compose.base.yml
#    (~/.ssh/config and ~/.ssh/known_hosts, read-only) land into an existing
#    dev-owned directory with correct perms. We deliberately do NOT bind-mount
#    ~/.ssh as a whole dir (see docker-compose.base.yml for why).
RUN install -d -o dev -g dev -m 700 /home/dev/.ssh

# ── Supabase CLI — pulled from GitHub releases because the npm package was
#    deprecated and there's no apt repo on Debian. The /releases/latest/ alias
#    tracks the most recent stable version, so base-image rebuilds pick up
#    updates without a Dockerfile edit.
RUN ARCH=$(dpkg --print-architecture) \
    && curl -fsSL "https://github.com/supabase/cli/releases/latest/download/supabase_linux_${ARCH}.tar.gz" \
       -o /tmp/supabase.tar.gz \
    && tar xzf /tmp/supabase.tar.gz -C /usr/local/bin supabase \
    && chmod +x /usr/local/bin/supabase \
    && rm /tmp/supabase.tar.gz
