#!/usr/bin/env zsh
# borg-notifyd — host daemon: fires macOS notifications when any project transitions to waiting
# Managed by launchd (com.stillpoint-labs.borg.notifyd). Not for direct invocation.

set -euo pipefail

export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH"

REGISTRY="${BORG_REGISTRY:-$HOME/.config/borg/registry.json}"
LOG_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/borg"
LOG="$LOG_DIR/notifyd.log"

log() { echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] $*" >> "$LOG" }

mkdir -p "$LOG_DIR"

for dep in fswatch jq osascript; do
    command -v "$dep" &>/dev/null || { log "ERROR: $dep not found in PATH"; exit 1 }
done

[[ -f "$HOME/.claude/lib/borg-hooks.sh" ]] || { log "ERROR: lib/borg-hooks.sh not installed — run borg setup"; exit 1 }
source "$HOME/.claude/lib/borg-hooks.sh"

[[ -f "$REGISTRY" ]] || { log "ERROR: registry not found: $REGISTRY"; exit 1 }

log "started. watching $REGISTRY"

typeset -A last_status

fire() {
    local project="$1" window="$2"
    local subtitle="${window:+$window — }$project"
    log "notify $project (window=${window:-none})"
    _borg_osa_notify "Claude Code" "$subtitle" "Ready for input"
}

check() {
    local silent="${1:-}"  # pass any non-empty string to record state without firing
    local lines
    lines=$(jq -r '.projects // {} | to_entries[] | "\(.key)\t\(.value.status // "idle")\t\(.value.tmux_window // "")\t\(.value.notify_origin // "")"' \
        "$REGISTRY" 2>/dev/null) || return 0
    local -A seen
    while IFS=$'\t' read -r project proj_status window origin; do
        seen[$project]=1
        local prev="${last_status[$project]:-}"
        last_status[$project]="$proj_status"
        # Only fire for container-origin transitions — host-origin is already handled by notify.sh
        [[ -z "$silent" && "$proj_status" == "waiting" && "$prev" != "waiting" && "$origin" == "container" ]] && fire "$project" "$window"
    done <<< "$lines"
    for key in "${(@k)last_status}"; do
        [[ -z "${seen[$key]:-}" ]] && unset "last_status[$key]"
    done
}

# Silent initial snapshot — record current state without firing to avoid startup floods
check silent

fswatch -o "$REGISTRY" | while read -r; do
    check
done
