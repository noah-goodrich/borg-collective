#!/usr/bin/env bash
# borg-usage-watch — host poller: sample `claude -p "/usage"` and log observations.
#
# Managed by launchd (phase 1: OBSERVE-ONLY — no checkpointing, no dispatch veto, no tmux
# writes of any kind). Each invocation does ONE sample then exits.
#
#   --once    Single sample then exit (default; same as no flag — explicit for clarity).
#   --debug   Log to stderr in addition to file.
#
# Samples land at $BORG_USAGE_SAMPLES (default ~/.local/state/borg/usage-samples.jsonl).
# Log lives at $BORG_USAGE_LOG (default ~/.local/state/borg/usage-watch.log).
#
# ── ROW SCHEMA (self-auditing contract) ──────────────────────────────────────────
# EVERY poll appends exactly one JSONL row to $BORG_USAGE_SAMPLES. Silence in the samples
# file has exactly one meaning: the poller did not run at all (e.g. launchd job disabled).
# All rows have `ts` (ISO8601 UTC) and `status`. `pane_count` (integer) is present on every
# row.
#
#   status:"ok"      session_pct, week_pct, resets_at populated as before.
#   status:"idle"     pane_count:0, session_pct/week_pct/resets_at:null. No claude panes AND
#                      no independent claude process detected either.
#   status:"suspect"  pane_count:0 but the independent process cross-check (proc_count > 0)
#                      disagrees — likely the pane-matching regex is blind to a real session.
#                      session_pct/week_pct/resets_at:null, same as idle otherwise.
#   status:"error"    session_pct/week_pct/resets_at:null, plus a `reason` field:
#                        "binary_not_found" — claude not resolvable on PATH (exit 1, permanent
#                                             misconfiguration).
#                        "claude_failed"    — claude ran but exited nonzero (exit 0, transient).
#                        "parse_failed"     — claude exited 0 but output didn't parse (exit 0).
#
# Rows written BEFORE this change have no `status` field at all — any consumer must treat a
# missing `status` key as `status:"ok"` (the old, only, format). The existing samples file is
# NOT rewritten or migrated.

set -euo pipefail

# Self-heal env FIRST — claude -p "/usage" prints nothing and exits 0 when USER is unset.
USER="${USER:-$(id -un)}"
export USER
HOME="${HOME:-$(eval echo "~$USER")}"
export HOME

# $HOME/.local/bin is where Claude Code's native installer puts `claude`. launchd hands jobs a
# minimal PATH that omits it, so leaving it out makes the poller permanently blind under launchd
# while still passing every manual run from a login shell.
export PATH="$HOME/.local/bin:/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH"

BORG_USAGE_CHECKPOINT_PCT="${BORG_USAGE_CHECKPOINT_PCT:-85}"
BORG_USAGE_HALT_PCT="${BORG_USAGE_HALT_PCT:-92}"

STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/borg"
SAMPLES="${BORG_USAGE_SAMPLES:-$STATE_DIR/usage-samples.jsonl}"
LOG="${BORG_USAGE_LOG:-$STATE_DIR/usage-watch.log}"

CLAUDE_BIN="${BORG_USAGE_CLAUDE_BIN:-claude}"

DEBUG=0
while [[ $# -gt 0 ]]; do
    case "$1" in
        --once)  shift ;;
        --debug) DEBUG=1; shift ;;
        *) echo "usage: borg-usage-watch [--once] [--debug]" >&2; exit 2 ;;
    esac
done

mkdir -p "$STATE_DIR"

log() {
    local line="[$(date -u +%Y-%m-%dT%H:%M:%SZ)] $*"
    echo "$line" >> "$LOG"
    (( DEBUG )) && echo "$line" >&2
    return 0
}

# Count tmux panes running Claude Code.
#
# A native-install Claude pane reports pane_current_command as its VERSION STRING ("2.1.205"),
# not "claude" — the binary lives at ~/.local/share/claude/versions/<version> and argv[0] is the
# version. Matching only /^claude$/ silently counts zero on every real machine, which would make
# this poller log "idle" forever and collect nothing. Keep the version alternative.
# (Older npm-style installs do exec a binary named `claude`, so both forms must match.)
#
# Overridable for tests via BORG_USAGE_PANE_CMD, which must print one line per pane.
_claude_pane_count() {
    local lister="tmux list-panes -a -F '#{pane_current_command}'"
    if [[ -n "${BORG_USAGE_PANE_CMD:-}" ]]; then
        lister="$BORG_USAGE_PANE_CMD"
    fi
    eval "$lister" 2>/dev/null | grep -cE '^(claude|[0-9]+\.[0-9]+\.[0-9]+)$' || true
}

# Independent, second detector of "is claude running" — the pane gate above cannot check itself
# (the version-named-pane bug was exactly the gate being wrong while reporting healthy). This
# looks for the actual OS process the native installer execs, entirely independent of tmux.
#
# Overridable for tests via BORG_USAGE_PROC_CMD, which must print one line per matching process.
_claude_proc_count() {
    local prober="pgrep -f '/\.local/share/claude/versions/'"
    if [[ -n "${BORG_USAGE_PROC_CMD:-}" ]]; then
        prober="$BORG_USAGE_PROC_CMD"
    fi
    eval "$prober" 2>/dev/null | grep -c . || true
}

# A single row is far below PIPE_BUF, so a plain O(1) append is already atomic. Do not
# "improve" this into a tmp+rename: that rewrites the whole file on every poll.
_append_sample() {
    printf '%s\n' "$1" >> "$SAMPLES"
}

# Log up to 400 chars of captured claude output (stdout+stderr merged, flattened to one line) so
# a future blind window is diagnosable after the fact. Never written to the JSONL row itself —
# log file only.
_log_output_excerpt() {
    local excerpt
    excerpt=$(printf '%s' "$1" | tr '\n' '|' | cut -c1-400)
    log "output excerpt (first 400 chars): $excerpt"
}

ts=$(date -u +%Y-%m-%dT%H:%M:%SZ)
pane_count=$(_claude_pane_count)
[[ -z "$pane_count" ]] && pane_count=0

if [[ "$pane_count" -eq 0 ]]; then
    proc_count=$(_claude_proc_count)
    [[ -z "$proc_count" ]] && proc_count=0
    if [[ "$proc_count" -gt 0 ]]; then
        log "WARNING: pane_count=0 but proc_count=$proc_count — tmux pane gate disagrees with the independent process check; marking suspect"
        row=$(jq -c -n --arg ts "$ts" --argjson pane_count "$pane_count" \
            '{ts:$ts, status:"suspect", pane_count:$pane_count, session_pct:null, week_pct:null, resets_at:null}')
        _append_sample "$row"
        exit 0
    fi
    log "debug: no claude panes running — skipping poll (idle)"
    row=$(jq -c -n --arg ts "$ts" --argjson pane_count "$pane_count" \
        '{ts:$ts, status:"idle", pane_count:$pane_count, session_pct:null, week_pct:null, resets_at:null}')
    _append_sample "$row"
    exit 0
fi

# An unresolvable binary is a permanent misconfiguration; an unparseable output is a transient
# format drift. Collapsing both into output="" reports the first as the second and still exits 0,
# so launchd reports the job healthy while it samples nothing. Fail loudly and distinctly instead.
if ! command -v "$CLAUDE_BIN" >/dev/null 2>&1; then
    log "ERROR: claude binary '$CLAUDE_BIN' not found on PATH ($PATH) — poller is blind, not idle"
    row=$(jq -c -n --arg ts "$ts" --argjson pane_count "$pane_count" \
        '{ts:$ts, status:"error", reason:"binary_not_found", pane_count:$pane_count, session_pct:null, week_pct:null, resets_at:null}')
    _append_sample "$row"
    exit 1
fi

# Each poll opens a real Claude Code session, so the token-cost SessionEnd hook would append a
# zero-token record to ~/.claude/token-spend.jsonl on every one — ~720/day, drowning real sessions
# in any count or average over that ledger. BORG_NO_SPEND_RECORD tells that hook to skip. Scoped to
# this invocation, not exported, so nothing else in the process inherits it.
claude_exit=0
output=$(BORG_NO_SPEND_RECORD=1 "$CLAUDE_BIN" -p "/usage" 2>&1) || claude_exit=$?

if [[ "$claude_exit" -ne 0 ]]; then
    log "ERROR: claude exited $claude_exit for '/usage' — poller could not sample"
    _log_output_excerpt "$output"
    row=$(jq -c -n --arg ts "$ts" --argjson pane_count "$pane_count" \
        '{ts:$ts, status:"error", reason:"claude_failed", pane_count:$pane_count, session_pct:null, week_pct:null, resets_at:null}')
    _append_sample "$row"
    exit 0
fi

session_line=$(echo "$output" | grep -oE 'Current session: [0-9]+% used · resets [^(]+' | head -1) || session_line=""
session_pct=$(echo "$session_line" | sed -E 's/^Current session: ([0-9]+)% used · resets .+$/\1/') || session_pct=""
if [[ "$session_pct" == "$session_line" ]]; then session_pct=""; fi
resets_at=$(echo "$session_line" | sed -E 's/^Current session: [0-9]+% used · resets (.+)$/\1/' | sed -E 's/ +$//') || resets_at=""
if [[ "$resets_at" == "$session_line" ]]; then resets_at=""; fi
week_line=$(echo "$output" | grep -oE 'Current week \(all models\): [0-9]+% used' | head -1) || week_line=""
week_pct=$(echo "$week_line" | sed -E 's/^Current week \(all models\): ([0-9]+)% used$/\1/') || week_pct=""
if [[ "$week_pct" == "$week_line" ]]; then week_pct=""; fi

if [[ -z "$session_pct" ]] || ! [[ "$session_pct" =~ ^[0-9]+$ ]] || [[ "$session_pct" -gt 100 ]]; then
    log "WARNING: could not parse session_pct from /usage output — state UNKNOWN"
    _log_output_excerpt "$output"
    row=$(jq -c -n --arg ts "$ts" --argjson pane_count "$pane_count" \
        '{ts:$ts, status:"error", reason:"parse_failed", pane_count:$pane_count, session_pct:null, week_pct:null, resets_at:null}')
    _append_sample "$row"
    exit 0
fi

if [[ -z "$week_pct" ]] || ! [[ "$week_pct" =~ ^[0-9]+$ ]]; then
    week_pct="null"
    week_pct_arg=(--argjson week_pct null)
else
    week_pct_arg=(--argjson week_pct "$week_pct")
fi

row=$(jq -c -n \
    --arg ts "$ts" \
    --argjson pane_count "$pane_count" \
    --argjson session_pct "$session_pct" \
    "${week_pct_arg[@]}" \
    --arg resets_at "$resets_at" \
    '{ts:$ts, status:"ok", pane_count:$pane_count, session_pct:$session_pct, week_pct:$week_pct, resets_at:$resets_at}')

_append_sample "$row"
log "sample: session_pct=$session_pct week_pct=$week_pct resets_at=$resets_at"

if (( session_pct >= BORG_USAGE_HALT_PCT )); then
    log "WARNING: session_pct=$session_pct >= halt threshold $BORG_USAGE_HALT_PCT (observe-only — no action taken)"
elif (( session_pct >= BORG_USAGE_CHECKPOINT_PCT )); then
    log "WARNING: session_pct=$session_pct >= checkpoint threshold $BORG_USAGE_CHECKPOINT_PCT (observe-only — no action taken)"
fi

exit 0
