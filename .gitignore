# Downloaded reference material (not source code)
*.mhtml
*.webp

# macOS
.DS_Store

# Runtime state (lives at ~/.config/borg/, not in repo) — but the parent
# .borg/ dir itself must stay traversable so the checkpoints/ carve-out works.
# Gitignore won't re-include files under an excluded directory, so we ignore
# /.borg/* (children, not the dir) and then exempt checkpoints/ below.
registry.json
.borg-project
.borg/*
!.borg/checkpoints/
!.borg/skill-extensions/

# Claude Code project-level settings and session state — local only
.claude/

# Runtime session state inside template scaffolds (same convention as root .borg/)
templates/supabase/.borg/
.borg/state.json
