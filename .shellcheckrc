# shellcheck configuration
# SC1090: Can't follow non-constant source — expected for dynamic lib loading
disable=SC1090
# SC1091: Not following sourced file — expected when sourcing from BORG_ROOT
disable=SC1091
# SC2034: Variable appears unused — zsh-specific patterns confuse shellcheck
disable=SC2034
# SC2155: Declare and assign separately — overly strict, these are safe in context
disable=SC2155
# SC2015: A && B || C is not if-then-else — intentional pattern in this codebase
disable=SC2015
